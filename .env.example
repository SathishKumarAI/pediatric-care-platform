# Copy to .env and edit. All values have safe local defaults; nothing required.

# --- LLM provider (env-switchable) ---
PROVIDER=ollama                 # ollama (free, local) | claude
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434
CLAUDE_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=            # only needed when PROVIDER=claude

# --- Knowledge graph (optional; in-memory fallback when unset) ---
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# --- Relational store ---
DATABASE_URL=sqlite:///./data/pcp.db

# --- Service ---
CORS_ORIGINS=http://localhost:3000,tauri://localhost
SYMPTOM_DATASET=data/symptom_disease.csv
